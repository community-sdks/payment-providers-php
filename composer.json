{
  "name": "community-sdks/payment-providers-php",
  "description": "Language-agnostic payment provider contract implementation for PHP with built-in Stripe, Paddle, and PayPal adapters.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "stripe/stripe-php": "^19.0",
    "paddlehq/paddle-php-sdk": "^1.16",
    "paypal/paypal-server-sdk": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "PaymentProviders\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PaymentProviders\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
